CREATE DATABASE kvalik_shop;
USE kvalik_shop;

CREATE TABLE users (
    user_id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(60) NOT NULL UNIQUE,
    password_hash VARCHAR(255) NOT NULL,
    role ENUM('guest','client','manager','admin') NOT NULL DEFAULT 'client',
    full_name VARCHAR(100) NOT NULL
);

CREATE TABLE categories (
    category_id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100) NOT NULL UNIQUE
);

CREATE TABLE products (
    product_id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(200) NOT NULL,
    description VARCHAR(200),
    price DECIMAL(10,2) NOT NULL,
    discount INT DEFAULT 0,
    image_path VARCHAR(500),
    sku VARCHAR(60) NOT NULL UNIQUE,
    
    category_id INT,
    FOREIGN KEY (category_id) REFERENCES categories(category_id)
);

CREATE TABLE product_variants (
    variant_id INT AUTO_INCREMENT PRIMARY KEY,
    size VARCHAR(10) NOT NULL,
    color VARCHAR(60) NOT NULL,
    stock_qty int DEFAULT 0,
    price_modifier DECIMAL(8,2) NOT NULL DEFAULT 0.00,
    
	product_id INT NOT NULL,
    FOREIGN KEY (product_id) REFERENCES products(product_id)
);

CREATE TABLE delivery_methods (
    delivery_method_id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    cost DECIMAL(8,2) NOT NULL DEFAULT 0.00,
    delivery_days TINYINT NOT NULL
);

CREATE TABLE orders (
    order_id INT AUTO_INCREMENT PRIMARY KEY,
    address VARCHAR(400) NOT NULL,
    total_amount DECIMAL(10,2) NOT NULL DEFAULT 0.00,
    status ENUM('новый','обработка','отправлено','доставлено','отменено','возврат') NOT NULL DEFAULT 'новый',
    payment_method ENUM('карта','наличные','онлайн') NOT NULL DEFAULT 'карта',
    order_date DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    delivery_date DATE,
    
	user_id INT,
    delivery_method_id INT,
    FOREIGN KEY (user_id) REFERENCES users(user_id),
    FOREIGN KEY (delivery_method_id) REFERENCES delivery_methods(delivery_method_id)
);

CREATE TABLE order_items (
    order_item_id INT AUTO_INCREMENT PRIMARY KEY,
    quantity int NOT NULL DEFAULT 1,
    price_at_order DECIMAL(10,2) NOT NULL,
    
    order_id INT NOT NULL,
    variant_id INT NOT NULL,
    FOREIGN KEY (order_id) REFERENCES orders(order_id),
    FOREIGN KEY (variant_id) REFERENCES product_variants(variant_id)
);

